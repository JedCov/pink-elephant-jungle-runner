{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "jsx": "react",
    "module": "ES2020",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "outDir": "dist",
    "skipLibCheck": true,
    "noEmitOnError": false
  },
  "include": ["src/**/*.jsx"]
}
